# Copy this file to .env and fill in real values.
# .env is loaded automatically (see main.py) — never commit your actual .env.
#
# Used by two different things:
#   - Running the app directly with `python main.py` / `uvicorn main:app`
#     (reads DATABASE_URL, SECRET_KEY, etc. below directly)
#   - `docker compose up` (reads POSTGRES_* below to configure the db
#     container, and reuses SECRET_KEY/SMTP_*/etc. for the api container —
#     see docker-compose.yml)

# ---------------------------------------------------------------------------
# Postgres container credentials (docker-compose only)
# ---------------------------------------------------------------------------
# REQUIRED if using docker compose — docker-compose.yml has no fallback for
# POSTGRES_PASSWORD on purpose (a hardcoded fallback here would mean a
# known password baked into a file meant to be committed to git). Pick
# your own password below; it only needs to be memorable to you.
POSTGRES_USER=bookingapp
POSTGRES_PASSWORD=change-me-to-your-own-password
POSTGRES_DB=bookings

# ---------------------------------------------------------------------------
# Database (required — the app refuses to start without a valid Postgres URL)
# ---------------------------------------------------------------------------
# For running the app directly (not via docker compose), point at localhost.
# Keep the password in sync with POSTGRES_PASSWORD above if you're also
# using docker compose for the database.
DATABASE_URL=postgresql://bookingapp:change-me-to-your-own-password@localhost:5432/bookings

# ---------------------------------------------------------------------------
# Auth (required for anything beyond a quick local test)
# ---------------------------------------------------------------------------
# Generate a real one with: python3 -c "import secrets; print(secrets.token_hex(32))"
# If unset, the app generates a random one on every restart — fine for a
# five-minute local test, but every login token breaks on restart.
SECRET_KEY=

# Minutes before a login token expires.
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---------------------------------------------------------------------------
# Logging (optional — sensible defaults if left unset)
# ---------------------------------------------------------------------------
LOG_DIR=logs
UPLOAD_LOG_DIR=upload_logs

# ---------------------------------------------------------------------------
# Daily summary email (optional — the feature is simply off if left unset)
# ---------------------------------------------------------------------------
# For LOCAL TESTING with no real mailbox: docker-compose.yml includes a
# "mailpit" service — a fake SMTP server with a web UI. Use these values
# and view "sent" emails at http://localhost:8025 instead of a real inbox:
#   SMTP_HOST=mailpit
#   SMTP_PORT=1025
#   SMTP_USE_TLS=false
#
# For a REAL provider (e.g. Gmail — needs an App Password, not your normal
# password: https://myaccount.google.com/apppasswords):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USERNAME=you@gmail.com
#   SMTP_PASSWORD=<16-character app password>
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=booking-manifest@example.com
SMTP_USE_TLS=true

# Comma-separated list, e.g.: ops@yourcompany.com,manager@yourcompany.com
SUMMARY_EMAIL_RECIPIENTS=

# Send time, in UTC.
SUMMARY_EMAIL_HOUR=7
SUMMARY_EMAIL_MINUTE=0
